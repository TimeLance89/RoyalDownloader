# Royal Downloader – Beispielkonfiguration für docker compose
# Kopieren: cp .env.example .env

TZ=Europe/Berlin

# Absolute Ordner auf dem NAS. Beide Ziele müssen für Docker beschreibbar sein.
MOVIES_HOST_DIR=/volume1/media/Filme
SERIES_HOST_DIR=/volume1/media/Serien

# Weboberfläche im LAN absichern.
APP_USERNAME=royal
APP_PASSWORD=CHANGE_ME

# Optional: im Einrichtungs-Wizard oder hier vorbelegen.
JELLYFIN_URL=http://192.168.1.10:8096
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=
JELLYFIN_USER_NAME=
TMDB_API_KEY=
TMDB_LANGUAGE=de-DE

# Oberfläche / Übersetzung
UI_LANGUAGE=de
# Optional: eigene LibreTranslate-Basis-URL statt des öffentlichen Google-Fallbacks.
UI_TRANSLATOR_URL=
UI_TRANSLATOR_API_KEY=
# Optional: SFlix-Spiegeldomain ohne Code-Update austauschen.
SFLIX_BASE_URL=https://sflix.win

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Seerr / Moonfin
SEERR_ENABLED=false
SEERR_URL=http://seerr:5055
SEERR_API_KEY=
SEERR_POLL_INTERVAL_SECONDS=60

# Automatik
AUTO_DOWNLOAD=false
CHECK_INTERVAL_MIN=30
DL_WINDOW_START=
DL_WINDOW_END=

# Updatequelle des öffentlichen Royal-Downloader-Repositorys.
UPDATE_GITHUB_REPOSITORY=TimeLance89/RoyalDownloader
UPDATE_GITHUB_BRANCH=main
UPDATE_MODE=manual
AUTO_UPDATE_INTERVAL_HOURS=6
YTDLP_AUTO_UPDATE=true
YTDLP_UPDATE_INTERVAL_HOURS=24
YTDLP_UPDATE_START_DELAY_SECONDS=300

# Netzwerk und Transfer
DNS_PRIMARY=1.1.1.1
DNS_SECONDARY=9.9.9.9
HLS_CONCURRENT_FRAGMENTS=4
MP4_HTTP_CHUNK_SIZE=4M
SLOW_DOWNLOAD_MIN_KIBPS=384
SLOW_DOWNLOAD_GRACE_SECONDS=45
SLOW_DOWNLOAD_WINDOW_SECONDS=90
