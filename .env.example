# Royal Downloader example configuration for Docker Compose
# Copy with: cp .env.example .env

TZ=Europe/Berlin

# Absolute NAS directories. Docker must have write access to both destinations.
MOVIES_HOST_DIR=/volume1/media/Filme
SERIES_HOST_DIR=/volume1/media/Serien

# Network exposure. Default 127.0.0.1 keeps both web interfaces reachable
# only from the Docker host. Set 0.0.0.0 for LAN access – credentials are
# then mandatory and the app refuses to start without them.
BIND_ADDRESS=127.0.0.1
SEERR_BIND_ADDRESS=127.0.0.1

# Protect the web interface, even on a trusted LAN.
APP_USERNAME=royal
APP_PASSWORD=CHANGE_ME

# Deliberate opt-out only (not recommended): allows running without login
# while the interface is exposed on the network.
#ALLOW_UNAUTHENTICATED_LAN=1

# Optional defaults for the onboarding wizard.
JELLYFIN_URL=http://192.168.1.10:8096
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=
JELLYFIN_USER_NAME=
TMDB_API_KEY=
TMDB_LANGUAGE=de-DE

# Interface and translation
UI_LANGUAGE=de
# Optional self-hosted LibreTranslate base URL instead of the public fallback.
UI_TRANSLATOR_URL=
UI_TRANSLATOR_API_KEY=

# Optional provider mirror overrides.
SFLIX_BASE_URL=https://sflix.win
RIDOMOVIES_BASE_URL=https://ridomovies.su

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Seerr and Moonfin
# Pinned Seerr release used by docker-compose; bump deliberately.
#SEERR_IMAGE_TAG=v3.0.1
SEERR_ENABLED=false
SEERR_URL=http://seerr:5055
SEERR_API_KEY=
SEERR_POLL_INTERVAL_SECONDS=60

# Automation
AUTO_DOWNLOAD=false
CHECK_INTERVAL_MIN=30
DL_WINDOW_START=
DL_WINDOW_END=

# Public Royal Downloader repository used by the updater. Deviating from the
# official source additionally requires UPDATE_ALLOW_CUSTOM_REPOSITORY=1,
# because updates are not cryptographically signed yet.
UPDATE_GITHUB_REPOSITORY=TimeLance89/RoyalDownloader
UPDATE_GITHUB_BRANCH=main
#UPDATE_ALLOW_CUSTOM_REPOSITORY=1
UPDATE_MODE=manual
AUTO_UPDATE_INTERVAL_HOURS=6
YTDLP_AUTO_UPDATE=true
YTDLP_UPDATE_INTERVAL_HOURS=24
YTDLP_UPDATE_START_DELAY_SECONDS=300

# Network and transfer tuning
DNS_PRIMARY=1.1.1.1
DNS_SECONDARY=9.9.9.9
HLS_CONCURRENT_FRAGMENTS=4
MP4_HTTP_CHUNK_SIZE=4M
SLOW_DOWNLOAD_MIN_KIBPS=384
SLOW_DOWNLOAD_GRACE_SECONDS=45
SLOW_DOWNLOAD_WINDOW_SECONDS=90
